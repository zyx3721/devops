const parentTitles: Record<string, { title: string; path?: string }> = {
  app: { title: '应用管理' },
  traffic: { title: '流量治理', path: '/traffic/ratelimit' },
  pipeline: { title: 'CI/CD 流水线', path: '/pipeline/list' },
  jenkins: { title: 'Jenkins' },
  k8s: { title: 'Kubernetes', path: '/k8s/clusters' },
  approval: { title: '发布审批' },
  message: { title: '消息通道' },
  oa: { title: 'OA' },
  alert: { title: '告警管理' },
  cost: { title: '成本管理', path: '/cost/overview' },
  logs: { title: '日志中心', path: '/logs/center' },
  system: { title: '系统管理' },
}

const breadcrumbs = computed(() => {
  const path = route.path
  const result: { title: string; path?: string }[] = [{ title: '首页', path: '/dashboard' }]
  
  // 处理动态路由，如 /pipeline/:id
  let matchedPath = path
  const config = breadcrumbMap[path]
  
  if (!config) {
    // 尝试匹配动态路由
    if (path.match(/^\/pipeline\/\d+$/)) {
      result.push({ title: 'CI/CD 流水线', path: '/pipeline/list' })
      result.push({ title: '流水线详情' })
      return result
    }
    if (path.match(/^\/pipeline\/edit\/\d+$/)) {
      result.push({ title: 'CI/CD 流水线', path: '/pipeline/list' })
      result.push({ title: '编辑流水线' })
      return result
    }
    if (path.match(/^\/k8s\/clusters\/\d+\/resources$/)) {
      result.push({ title: 'Kubernetes', path: '/k8s/clusters' })
      result.push({ title: '资源管理' })
      return result
    }
    if (path.match(/^\/k8s\/clusters\/\d+\/pods$/)) {
      result.push({ title: 'Kubernetes', path: '/k8s/clusters' })
      result.push({ title: 'Pod 管理' })
      return result
    }
    if (path.match(/^\/k8s\/clusters\/\d+\/deployments$/)) {
      result.push({ title: 'Kubernetes', path: '/k8s/clusters' })
      result.push({ title: 'Deployment 管理' })
      return result
    }
    if (path.match(/^\/jenkins\/instances\/\d+\/jobs$/)) {
      result.push({ title: 'Jenkins', path: '/jenkins/instances' })
      result.push({ title: 'Jobs' })
      return result
    }
    if (path.match(/^\/approval\/chains\/\d+\/design$/)) {
      result.push({ title: '发布审批' })
      result.push({ title: '审批链管理', path: '/approval/chains' })
      result.push({ title: '审批链设计' })
      return result
    }
    if (path.match(/^\/approval\/instances\/\d+$/)) {
      result.push({ title: '发布审批' })
      result.push({ title: '审批实例', path: '/approval/instances' })
      result.push({ title: '实例详情' })
      return result
    }
    return result
  }
  
  if (config.parent) {
    const parent = parentTitles[config.parent]
    if (parent) {
      result.push({ title: parent.title, path: parent.path })
    }
  }
  
  result.push({ title: config.title })
  return result
})

// 根据路径获取父菜单 key
const getParentKey = (path: string): string => {
  if (path.startsWith('/traffic/')) return 'traffic'
  if (path.startsWith('/applications') || path.startsWith('/deploys') || path.startsWith('/deploy/check') || path.startsWith('/canary') || path.startsWith('/bluegreen')) return 'app'
  if (path.startsWith('/pipeline')) return 'pipeline'
  if (path.startsWith('/jenkins')) return 'jenkins'
  if (path.startsWith('/k8s') || path.startsWith('/security')) return 'k8s'
  if (path.startsWith('/approval') || path.startsWith('/deploy/locks')) return 'approval'
  if (path.startsWith('/feishu') || path.startsWith('/dingtalk') || path.startsWith('/wechatwork')) return 'message'
  if (path.startsWith('/oa')) return 'oa'
  if (path.startsWith('/alert')) return 'alert'
  if (path.startsWith('/cost')) return 'cost'
  if (path.startsWith('/logs')) return 'logs'
  if (path.startsWith('/users') || path.startsWith('/rbac') || path.startsWith('/audit') || path.startsWith('/admin')) return 'system'
  return ''
}

const openKeys = ref<string[]>([getParentKey(route.path)].filter(Boolean))

const userInfo = computed(() => {
  const info = localStorage.getItem('userInfo')
  return info ? JSON.parse(info) : null
})

watch(() => route.path, (newPath) => {
  selectedKeys.value = [newPath]
  const parentKey = getParentKey(newPath)
  if (parentKey && !openKeys.value.includes(parentKey)) {
    openKeys.value = [...openKeys.value, parentKey]
  }
})

const handleMenuClick = ({ key }: { key: string }) => {
  router.push(key)
}

const handleDropdownClick = ({ key }: { key: string }) => {
  if (key === 'profile') {
    router.push('/profile')
  } else if (key === 'logout') {
    handleLogout()
  }
}

const handleLogout = () => {
  localStorage.removeItem('token')
  localStorage.removeItem('userInfo')
  message.success('已退出登录')
  router.push('/login')
}
